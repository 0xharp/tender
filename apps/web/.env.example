## Copy to .env.local and fill in. .env.local is gitignored. ##

NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_HELIUS_WSS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Optional override for the SNS RPC. Tendr now mints `<handle>.tendr.sol`
# subdomains under our own parent on DEVNET, so SNS reads run against the
# same devnet hierarchy as the rest of the app. If unset, defaults to the
# Helius devnet URL above. Override only if you want to route SNS traffic
# (especially `getProgramAccounts`) to a separate RPC project.
# NEXT_PUBLIC_SNS_RPC_URL=

# Server-only — base58 OR JSON-array secret key for the wallet that owns
# `tendr.sol` on devnet. Required for /api/identity/claim to mint
# subdomains. Set this to the contents of the keypair file you used to
# run `node apps/web/scripts/register-tendr-devnet.mjs` (typically
# ~/.config/solana/id.json — the registration script prints the exact
# value to paste).
TENDR_PARENT_OWNER_PRIVATE_KEY=

NEXT_PUBLIC_TENDER_PROGRAM_ID=

# QVAC LLM sidecar (apps/ai-sidecar/) — OpenAI-compatible HTTP API.
# Browser calls this URL DIRECTLY (no Tendr backend hop) for the three
# AI surfaces: RFP scope drafting, bid comparison, provider bid drafting.
# Unset = AI buttons hide themselves; the rest of the product works
# identically without AI. Local dev: http://localhost:11434/v1
# Nosana production: copy the endpoint URL from your Nosana dashboard
# after deploying the apps/ai-sidecar/Dockerfile container.
NEXT_PUBLIC_QVAC_BASE_URL=

# Optional API key for the QVAC sidecar. Leave unset for the default
# config (no auth). If you set --api-key on the sidecar, set the same
# value here so the OpenAI client passes it as a Bearer token.
NEXT_PUBLIC_QVAC_API_KEY=

# (Legacy — pre-QVAC integration. The Express stub at this URL was
# removed; kept here so older .env.local files don't break on import.
# Safe to delete.)
NEXT_PUBLIC_AI_SIDECAR_URL=

## Supabase ##
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only — never expose to browser. Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Server-only — Project Settings → API → JWT Settings → JWT Secret. Used to mint SIWS session JWTs.
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET
