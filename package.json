{
  "name": "tender",
  "version": "0.0.0",
  "private": true,
  "description": "Private procurement marketplace for crypto-native organizations on Solana",
  "license": "MIT",
  "author": "Harpreet Singh <0xharp> (https://github.com/0xharp)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xharp/tender.git"
  },
  "homepage": "https://github.com/0xharp/tender#readme",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:deploy": "anchor deploy --provider.cluster devnet"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
